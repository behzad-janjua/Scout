# Scout.ai environment variables

# --- Insforge (backend / database) ---
INSFORGE_API_URL=
INSFORGE_API_KEY=

# --- Vapi (voice AI mystery shopper) ---
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Shared secret used to verify inbound Vapi webhooks
VAPI_WEBHOOK_SECRET=

# --- Nebius (transcript analysis / reasoning) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=

# --- App ---
# Set to "true" to force the fallback demo path (no live calls / API needed)
SCOUT_DEMO_MODE=false
NEXT_PUBLIC_APP_NAME=Scout.ai

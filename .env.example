# Scout.ai environment template
#
# Copy this file to .env.local for local development.
# Keep .env.local out of git. Only commit this template.

# --- App ---
NEXT_PUBLIC_APP_NAME=Scout.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Real demo mode expects live Insforge, Vapi, and Nebius credentials.
SCOUT_DEMO_MODE=false

# --- Insforge: backend / database ---
# Required for persistent business, scenario, call, transcript, and report storage.
INSFORGE_API_URL=
INSFORGE_API_KEY=

# Optional, depending on the Insforge project setup.
INSFORGE_PROJECT_ID=
INSFORGE_DATABASE_ID=

# --- Vapi: voice AI mystery shopper ---
# Required to place real outbound mystery shopper calls.
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# Public webhook URL that Vapi should call.
# Local development usually needs a tunnel such as ngrok.
VAPI_WEBHOOK_URL=http://localhost:3000/api/calls/webhook

# Shared secret used to verify inbound Vapi webhooks (sent as the
# `x-vapi-secret` header). Leave blank to accept all webhooks (demo-friendly).
VAPI_WEBHOOK_SECRET=

# Callback number the mystery shopper gives when an employee asks for one.
VAPI_DEMO_CUSTOMER_PHONE=+15555550123

# --- Nebius: transcript analysis / reasoning ---
# Required to analyze real transcripts instead of loading fixture JSON.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=
